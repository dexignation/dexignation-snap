{
  "name": "@dexignation/snap",
  "version": "0.1.0",
  "description": "Resolve .dex domains in MetaMask - Dexignation Web3 Name Service on Polygon.",
  "keywords": [
    "dexignation",
    "metamask",
    "snap",
    "snaps",
    "web3",
    "nameservice",
    "name-lookup",
    "domains"
  ],
  "homepage": "https://www.dexignation.com",
  "bugs": {
    "url": "https://github.com/DEXignation/dexignation-snap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEXignation/dexignation-snap.git"
  },
  "license": "MIT",
  "author": "SMB Labs",
  "type": "module",
  "main": "./dist/bundle.js",
  "files": [
    "dist/",
    "images/",
    "snap.manifest.json"
  ],
  "scripts": {
    "build": "mm-snap build",
    "build:clean": "npm run clean && npm run build",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "manifest": "mm-snap manifest --fix",
    "prepublishOnly": "mm-snap manifest",
    "serve": "mm-snap serve",
    "site": "npm --prefix site run start",
    "site:build": "npm --prefix site run build",
    "start": "mm-snap watch",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "~10.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@metamask/snaps-cli": "^8.3.0",
    "@metamask/snaps-jest": "^9.8.0",
    "@types/react": "18.2.4",
    "@types/react-dom": "18.2.4",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.5.0",
    "prettier": "^3.4.2",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.1.0",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
