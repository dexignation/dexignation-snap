{
  "name": "@dexignation/snap",
  "version": "0.1.0",
  "description": "MetaMask Snap that resolves DEXignation .dex names inside MetaMask.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DEXignation/dexignation-snap.git"
  },
  "homepage": "https://dexignation.com",
  "bugs": {
    "url": "https://github.com/DEXignation/dexignation-snap/issues"
  },
  "type": "module",
  "main": "dist/bundle.js",
  "files": [
    "dist",
    "images",
    "snap.manifest.json"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "mm-snap build",
    "build:clean": "mm-snap build --clean",
    "serve": "mm-snap serve",
    "watch": "mm-snap watch",
    "start": "mm-snap watch",
    "manifest": "mm-snap manifest --fix",
    "test": "vitest run",
    "lint": "eslint src --ext .ts && prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint src --ext .ts --fix && prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "^6.7.0",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@metamask/snaps-cli": "^6.5.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
